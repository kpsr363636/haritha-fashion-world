# ============================================================
# Haritha Fashion World — Backend Environment Variables
# Copy to .env and fill in values for local development
# ============================================================

# Database (local docker-compose defaults)
# Database (Postgres.app — ./scripts/fix-postgres-5432.sh then start-postgres.sh)
DB_URL=jdbc:postgresql://localhost:5432/haritha_fashion
DB_USER=postgres
DB_PASSWORD=postgres
USE_EXTERNAL_DB=true

# Redis (local docker-compose defaults)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — minimum 32 characters, use a strong random secret in production
JWT_SECRET=your-256-bit-secret-change-in-production-minimum-32-chars

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=haritha-fashion-media
CLOUDFRONT_DOMAIN=https://dxxxxxx.cloudfront.net

# MSG91 — OTP + WhatsApp
MSG91_API_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_WA_ORDER_TEMPLATE=
MSG91_WA_SHIPPED_TEMPLATE=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PAYOUT_ACCOUNT=

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary

# Google OAuth2 (optional for local dev)
GOOGLE_CLIENT_ID=

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev
