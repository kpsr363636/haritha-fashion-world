# ============================================================
# Haritha Fashion World — Root Environment Variables
# Used by docker-compose and local development orchestration
# ============================================================

# PostgreSQL (docker-compose)
POSTGRES_DB=haritha_fashion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend — see backend/.env.example for full list
DB_URL=jdbc:postgresql://localhost:5432/haritha_fashion
DB_USER=postgres
DB_PASSWORD=postgres
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=your-256-bit-secret-change-in-production-minimum-32-chars
SPRING_PROFILES_ACTIVE=dev

# Frontend — see frontend/.env.example for full list
VITE_API_URL=http://localhost:8080/api
